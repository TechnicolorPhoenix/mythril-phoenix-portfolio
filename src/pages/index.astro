---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { Github, Globe, Play } from '@lucide/astro';

const projects = [
  {
    title: "Project Name",
    description: "Briefly explain the tech stack and your 'Polymath' role here.",
    tags: ["Astro", "C#", "Unity"],
    video: "/videos/project-demo.mp4",
    github: "https://github.com/hickersonloren",
    link: "#"
  },
  // Add more projects here
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			/* ── Page-level layout ──────────────────────────────────────────── */
			body {
				background-color: #0B0C0E;
				padding-top: 64px;
			}

			.page-content {
				max-width: 1100px;
				margin: 0 auto;
				padding: 0 2rem;
			}

			/* ── Hero ───────────────────────────────────────────────────────── */
			.hero-section {
				padding: 5rem 0 0;
				display: flex;
				flex-direction: column;
				align-items: center;
				text-align: center;
			}

			.hero-video-spacer {
				padding-bottom: 1rem;
				width: 100%;
				display: flex;
				justify-content: center;
			}

			.hero-video-wrapper {
				position: relative;
				width: 100%;
				max-width: 900px;
				aspect-ratio: 16 / 9;
				border-radius: 4px;
				overflow: hidden;
				/* PALETTE: gold top border, cobalt glow in shadow */
				border: 0.5px solid rgba(201,168,76,0.3);
				box-shadow: 0 0 0 1px rgba(43,95,217,0.12), 0 0 60px rgba(0,0,0,0.7);
				margin-bottom: 3.5rem;
			}

			.hero-video-wrapper video {
				width: 100%; height: 100%;
				object-fit: cover;
				display: block;
			}

			.hero-play-overlay {
				position: absolute;
				inset: 0;
				display: flex;
				align-items: center;
				justify-content: center;
				background: rgba(0,0,0,0.35);
				opacity: 0;
				transition: opacity 0.2s;
				cursor: pointer;
			}
			.hero-video-wrapper:hover .hero-play-overlay { opacity: 1; }

			/* PALETTE: reel label in cornflower — ambient, informational */
			.hero-reel-label {
				position: absolute;
				bottom: 1rem; left: 1.25rem;
				font-family: 'Courier New', monospace;
				font-size: 0.65rem;
				font-weight: 700;
				letter-spacing: 0.2em;
				text-transform: uppercase;
				color: #6B9BF2;
				pointer-events: none;
			}

			/* PALETTE: name sweeps gold → white → cornflower */
			.hero-name {
				font-size: clamp(3rem, 9vw, 6.5rem);
				font-weight: 900;
				letter-spacing: -0.02em;
				line-height: 0.95;
				color: #F0EDE6;
				background: linear-gradient(125deg, #C9A84C 0%, #F0EDE6 45%, #6B9BF2 100%);
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
				background-clip: text;
				margin-bottom: 1.25rem;
			}

			.hero-tagline {
				color: #9A9590;
				font-size: clamp(0.95rem, 2vw, 1.1rem);
				max-width: 560px;
				margin: 0 auto 2.5rem;
				line-height: 1.7;
			}

			.hero-cta-group {
				display: flex;
				gap: 1rem;
				justify-content: center;
				flex-wrap: wrap;
				padding-bottom: 5rem;
			}

			.btn {
				display: inline-flex;
				align-items: center;
				gap: 0.5rem;
				padding: 0.7rem 1.8rem;
				border-radius: 2px;
				font-family: 'Courier New', monospace;
				font-size: 0.72rem;
				font-weight: 700;
				letter-spacing: 0.15em;
				text-transform: uppercase;
				text-decoration: none;
				transition: all 0.2s;
			}
			/* PALETTE: primary CTA gold — brand/identity action */
			.btn-primary {
				background: #C9A84C;
				color: #0B0C0E;
				border: none;
			}
			.btn-primary:hover {
				background: #ddb95a;
				color: #0B0C0E;
				transform: translateY(-1px);
			}
			/* PALETTE: secondary CTA cobalt — technical/interactive action */
			.btn-ghost {
				background: transparent;
				color: #6B9BF2;
				border: 0.5px solid rgba(43,95,217,0.4);
			}
			.btn-ghost:hover {
				background: rgba(43,95,217,0.08);
				border-color: #6B9BF2;
				color: #93b8ff;
			}

			/* ── Skills ticker ──────────────────────────────────────────────── */
			.skills-strip {
				/* PALETTE: darker strip with cobalt border tint */
				background: #0E1018;
				border-top: 0.5px solid rgba(43,95,217,0.18);
				border-bottom: 0.5px solid rgba(43,95,217,0.18);
				padding: 1.25rem 0;
				overflow: hidden;
				position: relative;
			}

			.skills-scroll {
				display: flex;
				gap: 1.5rem;
				animation: scrollLeft 28s linear infinite;
				width: max-content;
				align-items: center;
			}

			.skill-chip {
				display: flex;
				align-items: center;
				gap: 0.4rem;
				font-family: 'Courier New', monospace;
				font-size: 0.68rem;
				font-weight: 700;
				letter-spacing: 0.1em;
				text-transform: uppercase;
				color: #9A9590;
				white-space: nowrap;
				padding: 0.25rem 0.8rem;
				/* PALETTE: cobalt-tinted chip border */
				border: 0.5px solid rgba(43,95,217,0.2);
				border-radius: 2px;
			}
			/* PALETTE: alternating gold/cobalt dots for rhythm */
			.skill-chip:nth-child(odd)::before {
				content: '';
				width: 4px; height: 4px;
				border-radius: 50%;
				background: #C9A84C;
				flex-shrink: 0;
			}
			.skill-chip:nth-child(even)::before {
				content: '';
				width: 4px; height: 4px;
				border-radius: 50%;
				background: #2B5FD9;
				flex-shrink: 0;
			}

			@keyframes scrollLeft {
				from { transform: translateX(0); }
				to   { transform: translateX(-50%); }
			}

			/* ── Section labels ─────────────────────────────────────────────── */
			.section-label {
				font-family: 'Courier New', monospace;
				font-size: 0.68rem;
				font-weight: 700;
				letter-spacing: 0.28em;
				text-transform: uppercase;
				/* PALETTE: label is gold */
				color: #C9A84C;
				margin-bottom: 0.75rem;
				display: flex;
				align-items: center;
				gap: 0.75rem;
			}
			/* PALETTE: rule fades gold into cobalt */
			.section-label::after {
				content: '';
				height: 0.5px;
				width: 60px;
				background: linear-gradient(to right, rgba(201,168,76,0.6), rgba(43,95,217,0.35));
			}

			.section-heading {
				color: #F0EDE6;
				font-size: clamp(1.8rem, 4vw, 2.8rem);
				font-weight: 900;
				letter-spacing: -0.01em;
				margin-bottom: 3rem;
			}

			/* ── Featured Work ──────────────────────────────────────────────── */
			.section-work { padding: 5rem 0; }

			.projects-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
				gap: 1.5rem;
			}

			.project-card {
				background: #161A22;
				border: 0.5px solid rgba(255,255,255,0.07);
				overflow: hidden;
				transition: border-color 0.25s, transform 0.25s, box-shadow 0.25s;
			}
			/* PALETTE: card hover glows cobalt */
			.project-card:hover {
				border-color: rgba(43,95,217,0.45);
				transform: translateY(-3px);
				box-shadow: 0 8px 32px rgba(43,95,217,0.1);
			}

			/* PALETTE: gold-to-cobalt bar sweeps in on card hover */
			.project-card::before {
				content: '';
				display: block;
				height: 2px;
				background: linear-gradient(to right, #C9A84C, #2B5FD9);
				transform: scaleX(0);
				transform-origin: left;
				transition: transform 0.3s ease;
			}
			.project-card:hover::before { transform: scaleX(1); }

			.project-media {
				aspect-ratio: 16 / 9;
				overflow: hidden;
				background: #0d1017;
				position: relative;
			}
			.project-media video,
			.project-media img {
				width: 100%; height: 100%;
				object-fit: cover;
				display: block;
				transition: transform 0.4s, opacity 0.3s;
				opacity: 0.75;
			}
			.project-card:hover .project-media video,
			.project-card:hover .project-media img {
				transform: scale(1.04);
				opacity: 1;
			}

			.project-body { padding: 1.5rem; }

			.project-title {
				color: #F0EDE6;
				font-size: 1.2rem;
				font-weight: 700;
				margin-bottom: 0.5rem;
			}

			.project-desc {
				color: #9A9590;
				font-size: 0.875rem;
				line-height: 1.65;
				margin-bottom: 1.25rem;
			}

			.project-tags {
				display: flex;
				flex-wrap: wrap;
				gap: 0.4rem;
				margin-bottom: 1.25rem;
			}

			/* PALETTE: tags cycle gold / cobalt / cornflower */
			.project-tag {
				font-family: 'Courier New', monospace;
				font-size: 0.6rem;
				font-weight: 700;
				letter-spacing: 0.1em;
				text-transform: uppercase;
				padding: 0.2rem 0.6rem;
				border-radius: 2px;
			}
			.project-tag:nth-child(3n+1) {
				background: rgba(201,168,76,0.08);
				color: #C9A84C;
				border: 0.5px solid rgba(201,168,76,0.22);
			}
			.project-tag:nth-child(3n+2) {
				background: rgba(43,95,217,0.08);
				color: #6B9BF2;
				border: 0.5px solid rgba(43,95,217,0.22);
			}
			.project-tag:nth-child(3n) {
				background: rgba(107,155,242,0.06);
				color: #93b8ff;
				border: 0.5px solid rgba(107,155,242,0.18);
			}

			.project-links {
				display: flex;
				gap: 1.25rem;
				padding-top: 1rem;
				border-top: 0.5px solid rgba(255,255,255,0.07);
			}

			.project-link {
				display: flex;
				align-items: center;
				gap: 0.4rem;
				font-family: 'Courier New', monospace;
				font-size: 0.65rem;
				font-weight: 700;
				letter-spacing: 0.1em;
				text-transform: uppercase;
				color: #5C5850;
				text-decoration: none;
				transition: color 0.2s;
			}
			/* PALETTE: Source → gold, Live → cobalt */
			.project-link:first-child:hover { color: #C9A84C; }
			.project-link:last-child:hover  { color: #6B9BF2; }

			/* ── Credits table ──────────────────────────────────────────────── */
			.section-credits {
				padding: 5rem 0;
				border-top: 0.5px solid rgba(255,255,255,0.07);
			}

			.credits-table {
				width: 100%;
				border-collapse: collapse;
				font-size: 0.9rem;
			}

			.credits-table thead tr {
				/* PALETTE: header rule is a gold-to-cobalt gradient line */
				border-bottom: 1px solid;
				border-image: linear-gradient(to right, rgba(201,168,76,0.5), rgba(43,95,217,0.35)) 1;
			}

			.credits-table th {
				font-family: 'Courier New', monospace;
				font-size: 0.62rem;
				font-weight: 700;
				letter-spacing: 0.22em;
				text-transform: uppercase;
				color: #C9A84C;
				padding: 0.75rem 0.75rem 0.75rem 0;
				text-align: left;
			}

			.credits-table td {
				padding: 1rem 0.75rem 1rem 0;
				border-bottom: 0.5px solid rgba(255,255,255,0.06);
				vertical-align: middle;
				color: #F0EDE6;
			}

			.credits-table tr:last-child td { border-bottom: none; }
			/* PALETTE: row hover shimmer blends gold and cobalt */
			.credits-table tbody tr:hover td {
				background: linear-gradient(to right, rgba(201,168,76,0.03), rgba(43,95,217,0.05));
			}

			.td-year {
				font-family: 'Courier New', monospace;
				font-size: 0.8rem;
				color: #5C5850 !important;
				letter-spacing: 0.06em;
			}

			.td-project {
				font-weight: 700;
				color: #F0EDE6 !important;
			}

			/* PALETTE: role column is cornflower — technical category */
			.td-role { color: #6B9BF2 !important; }

			.status-pill {
				display: inline-flex;
				align-items: center;
				gap: 0.35rem;
				font-family: 'Courier New', monospace;
				font-size: 0.6rem;
				font-weight: 700;
				letter-spacing: 0.1em;
				text-transform: uppercase;
				padding: 0.22rem 0.65rem;
				border-radius: 2px;
			}
			/* PALETTE: released = cobalt (complete/technical), wip = gold (in progress/craft) */
			.status-pill.released {
				background: rgba(43,95,217,0.1);
				color: #6B9BF2;
				border: 0.5px solid rgba(43,95,217,0.25);
			}
			.status-pill.wip {
				background: rgba(201,168,76,0.1);
				color: #C9A84C;
				border: 0.5px solid rgba(201,168,76,0.25);
			}
			.status-pill.cancelled {
				background: rgba(180,60,60,0.1);
				color: #E07070;
				border: 0.5px solid rgba(180,60,60,0.2);
			}
			.status-dot {
				width: 5px; height: 5px;
				border-radius: 50%;
				flex-shrink: 0;
			}
			.released  .status-dot { background: #2B5FD9; }
			.wip       .status-dot { background: #C9A84C; }
			.cancelled .status-dot { background: #E07070; }
		</style>
	</head>
	<body>
		<Header />

		<main>
			<div class="page-content">
				<section class="hero-section">

					<div class="hero-video-spacer">
						<div class="hero-video-wrapper">
							<video autoplay muted loop playsinline>
								<source src="/videos/demo-reel.mp4" type="video/mp4" />
							</video>
							<div class="hero-play-overlay" aria-hidden="true">
								<Play size={56} color="#C9A84C" />
							</div>
							<span class="hero-reel-label">Demo Reel 2024</span>
						</div>
					</div>

					<h1 class="hero-name">MYTHRIL PHOENIX</h1>
					<p class="hero-tagline">
						Gameplay Programmer &amp; Systems Architect. I build immersive worlds and the code that powers them.
					</p>
					<div class="hero-cta-group">
						<a href="#work" class="btn btn-primary">View My Work</a>
						<a href="#contact" class="btn btn-ghost">Get in Touch</a>
					</div>
				</section>
			</div>

			<!-- ── Skills ticker ──────────────────────────────────────────── -->
			<div class="skills-strip">
				<div class="skills-scroll" aria-hidden="true">
					{["C#","Unity","Unreal Engine","C++","Gameplay Systems","AI & Behavior Trees","Procedural Generation","Shader Dev","Combat Systems","Blueprint Scripting","Networking","Git"].map(s => (
						<span class="skill-chip">{s}</span>
					))}
					{["C#","Unity","Unreal Engine","C++","Gameplay Systems","AI & Behavior Trees","Procedural Generation","Shader Dev","Combat Systems","Blueprint Scripting","Networking","Git"].map(s => (
						<span class="skill-chip">{s}</span>
					))}
				</div>
			</div>

			<div class="page-content">

				<!-- ── Featured Work ───────────────────────────────────────── -->
				<section class="section-work" id="work">
					<p class="section-label">Selected Projects</p>
					<h2 class="section-heading">Featured Work</h2>

					<div class="projects-grid">
						{projects.map((project) => (
							<div class="project-card">
								<div class="project-media">
									<video
										src={project.video}
										muted loop playsinline
										onmouseover="this.play()"
										onmouseout="this.pause()"
									/>
								</div>
								<div class="project-body">
									<h3 class="project-title">{project.title}</h3>
									<p class="project-desc">{project.description}</p>
									<div class="project-tags">
										{project.tags.map(tag => (
											<span class="project-tag">{tag}</span>
										))}
									</div>
									<div class="project-links">
										{project.github && (
											<a href={project.github} class="project-link" target="_blank" rel="noopener">
												<Github size={14} /> Source
											</a>
										)}
										{project.link && project.link !== "#" && (
											<a href={project.link} class="project-link" target="_blank" rel="noopener">
												<Globe size={14} /> Live
											</a>
										)}
									</div>
								</div>
							</div>
						))}
					</div>
				</section>

				<!-- ── Professional Credits ───────────────────────────────── -->
				<section class="section-credits" id="credits">
					<p class="section-label">Industry Work</p>
					<h2 class="section-heading">Professional Credits</h2>

					<div style="overflow-x: auto;">
						<table class="credits-table">
							<thead>
								<tr>
									<th>Year</th>
									<th>Project</th>
									<th>Role</th>
									<th>Status</th>
								</tr>
							</thead>
							<tbody>
								<tr>
									<td class="td-year">2024</td>
									<td class="td-project">Your Game Title</td>
									<td class="td-role">Lead Coder</td>
									<td>
										<span class="status-pill released">
											<span class="status-dot"></span>
											Public Release
										</span>
									</td>
								</tr>
							</tbody>
						</table>
					</div>
				</section>

			</div>
		</main>

		<Footer />
	</body>
</html>
