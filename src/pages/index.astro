---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { Github, Globe, Gamepad2, FileCode, Play } from '@lucide/astro';

// Placeholder data - You can move this to a separate JSON/Content Collection later
const projects = [
  {
    title: "Project Name",
    description: "Briefly explain the tech stack and your 'Polymath' role here.",
    tags: ["Astro", "C#", "Unity"],
    video: "/videos/project-demo.mp4", // Put your mp4s in public/videos/
    github: "https://github.com/hickersonloren",
    link: "#"
  },
  // Add more here...
];
---

<!doctype html>
<html lang="en" class="bg-slate-950 text-slate-200">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="max-w-6xl mx-auto px-6">
			
			<section class="py-20 flex flex-col items-center text-center">
				<div class="relative w-full max-w-4xl aspect-video rounded-2xl overflow-hidden border border-slate-800 shadow-2xl mb-10 group">
					<div class="absolute inset-0 bg-blue-600/10 mix-blend-overlay z-10 pointer-events-none"></div>
					<video autoplay muted loop playsinline class="w-full h-full object-cover">
						<source src="/videos/demo-reel.mp4" type="video/mp4" />
					</video>
					<div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity bg-black/40">
						<Play size={64} class="text-white fill-current" />
					</div>
				</div>
				<h1 class="text-5xl md:text-7xl font-indigo-200 tracking-tighter text-white">MYTHRIL PHOENIX</h1>
				<p class="mt-4 text-xl text-slate-400 max-w-2xl">
					Gameplay Programmer & Systems Architect. I build immersive worlds and the code that powers them.
				</p>
			</section>

			<section class="py-20">
				<h2 class="text-3xl font-bold text-white mb-12 flex items-center gap-3">
					<FileCode class="text-indigo-200" /> Featured Work
				</h2>
				<div class="grid md:grid-cols-2 gap-8">
					{projects.map((project) => (
						<div class="group bg-slate-900 border border-slate-800 rounded-xl overflow-hidden hover:border-blue-500/50 transition-all">
							<div class="aspect-video bg-slate-800 relative">
								<video src={project.video} muted loop playsinline onmouseover="this.play()" onmouseout="this.pause()" class="w-full h-full object-cover opacity-80 group-hover:opacity-100 transition-opacity"></video>
							</div>
							<div class="p-6">
								<h3 class="text-xl font-bold text-white">{project.title}</h3>
								<p class="text-slate-400 mt-2 mb-4">{project.description}</p>
								<div class="flex flex-wrap gap-2 mb-6">
									{project.tags.map(tag => (
										<span class="text-[10px] uppercase tracking-widest bg-blue-500/10 text-blue-400 px-2 py-1 rounded border border-blue-500/20">{tag}</span>
									))}
								</div>
								<div class="flex gap-4">
									<a href={project.github} class="hover:text-white transition-colors"><Github size={20} /></a>
									<a href={project.link} class="hover:text-white transition-colors"><Globe size={20} /></a>
								</div>
							</div>
						</div>
					))}
				</div>
			</section>

			<section class="py-20 border-t border-slate-900">
				<h2 class="text-3xl font-bold text-white mb-10">Professional Credits</h2>
				<div class="overflow-x-auto">
					<table class="w-full text-left">
						<thead class="text-slate-500 uppercase text-xs tracking-widest border-b border-slate-900">
							<tr>
								<th class="pb-4">Year</th>
								<th class="pb-4">Project</th>
								<th class="pb-4">Role</th>
								<th class="pb-4">Status</th>
							</tr>
						</thead>
						<tbody class="divide-y divide-slate-900">
							<tr class="hover:bg-slate-900/30">
								<td class="py-4 font-mono">2024</td>
								<td class="py-4 text-white font-semibold">Your Game Title</td>
								<td class="py-4 text-blue-400">Lead Coder</td>
								<td class="py-4 text-xs">Public Release</td>
							</tr>
						</tbody>
					</table>
				</div>
			</section>

		</main>
		<Footer />
	</body>
</html>npm
